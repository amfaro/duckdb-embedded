#!/usr/bin/env bash
#MISE description="Prepare or update the release PR"
#MISE hide=true

set -euo pipefail

duckdb_version=$(sed -nE 's/^DUCKDB_VERSION = "([^"]+)"$/\1/p' mise.toml)
if [[ -z "${duckdb_version}" ]]; then
  echo "ERROR: failed to read DUCKDB_VERSION from mise.toml"
  exit 1
fi

max_build=$(git tag -l "v${duckdb_version}-*" | sed -nE "s/^v${duckdb_version}-([0-9]+)$/\1/p" | sort -n | tail -1)
if [[ -n "${max_build}" ]]; then
  next_build=$((max_build + 1))
else
  next_build=1
fi

release_version="v${duckdb_version}-${next_build}"
branch="release/${release_version}"

git config user.name "github-actions"
git config user.email "github-actions@github.com"
git checkout -B "${branch}" origin/main

current_version=""
if [[ -f VERSION ]]; then
  current_version="$(tr -d '\n' < VERSION)"
fi

if [[ "${current_version}" == "${release_version}" ]]; then
  echo "VERSION already set to ${release_version}; nothing to do"
  exit 0
fi

printf '%s\n' "${release_version}" > VERSION

git add VERSION
git commit -m "chore(release): prepare ${release_version}"
git push --force-with-lease origin "${branch}"

pr_body=$(cat <<EOF
Prepare \
`${release_version}`.

This PR updates `VERSION` to the next release tag inferred from `DUCKDB_VERSION` in `mise.toml` and the existing `v${duckdb_version}-*` tags.

After this PR merges:

- `tag-release.yml` runs on the `main` push that includes `VERSION` and creates the matching git tag
- `release.yml` runs on that tag push, publishes artifacts, and dispatches `duckdb-embedded-release` to `amfaro/calc`
EOF
)

pr_number=$(gh pr list \
  --head "${branch}" \
  --base main \
  --state open \
  --json number \
  --jq '.[0].number')

if [[ -n "${pr_number}" ]]; then
  gh pr edit "${pr_number}" \
    --title "chore(release): ${release_version}" \
    --body "${pr_body}"
else
  gh pr create \
    --base main \
    --head "${branch}" \
    --title "chore(release): ${release_version}" \
    --body "${pr_body}"
fi
